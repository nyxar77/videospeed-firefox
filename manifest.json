{
  "name": "Video Speed Controller",
  "short_name": "videospeed",
  "version": "0.0.0",
  "manifest_version": 3,
  "description": "Speed up, slow down, advance and rewind HTML5 audio/video with shortcuts",
  "homepage_url": "https://github.com/nyxar/videospeed-firefox",
  "browser_specific_settings": {
    "gecko": {
      "strict_min_version": "121.0"
    }
  },
  "icons": {
    "16": "dist/assets/icons/icon16.png",
    "48": "dist/assets/icons/icon48.png",
    "128": "dist/assets/icons/icon128.png"
  },
  "permissions": ["storage"],
  "background": {
    "scripts": ["dist/background.js"]
  },
  "options_ui": {
    "page": "dist/ui/options/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": {
      "19": "dist/assets/icons/icon19.png",
      "38": "dist/assets/icons/icon38.png",
      "48": "dist/assets/icons/icon48.png"
    },
    "default_popup": "dist/ui/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "all_frames": true,
      "match_about_blank": true,
      "exclude_matches": ["https://hangouts.google.com/*", "https://meet.google.com/*"],
      "js": ["dist/content-bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "all_frames": true,
      "match_about_blank": true,
      "exclude_matches": ["https://hangouts.google.com/*", "https://meet.google.com/*"],
      "css": ["dist/styles/inject.css"],
      "js": ["dist/inject.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
